<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The app stays NON-sandboxed (it reads ~/.claude config files); it only
	     needs the App Group to share the widget snapshot. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>V3P5U9Z68M.group.com.nhannht.ncomphunt</string>
	</array>
</dict>
</plist>
